# Hailo Switcher Environment Configuration
# Copy to .env and modify as needed

# Path to hailo-rpi5-examples installation
# HAILO_EXAMPLES_DIR=/home/ama/hailo/hailo-rpi5-examples

# Python binary (defaults to venv inside HAILO_EXAMPLES_DIR)
# HAILO_PYTHON_BIN=/path/to/python

# Hailo environment file
# HAILO_ENV_FILE=/path/to/.env

# GStreamer plugin path
# GST_PLUGIN_PATH=/usr/lib/aarch64-linux-gnu/gstreamer-1.0

# Hailo post-process shared library search path
# HAILO_LD_LIBRARY_PATH=/usr/lib/aarch64-linux-gnu/hailo/tappas/post_processes:/usr/local/hailo/resources/so

# rpicam-apps post-process JSON directory
# RPICAM_ASSETS_DIR=/usr/share/rpi-camera-assets
